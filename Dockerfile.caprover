FROM node:22-bookworm-slim AS web_builder

WORKDIR /src

# Build only the dashboard bundle from this repo. The runtime image below is the
# published Hermes image; replacing web_dist is enough for dashboard-only fixes.
COPY package.json package-lock.json ./
COPY web/package.json web/
COPY apps/shared/ apps/shared/

RUN npm install --workspace web --prefer-offline --no-audit

COPY web/ web/

RUN cd web && npm run build

FROM nousresearch/hermes-agent:latest

COPY --from=web_builder /src/hermes_cli/web_dist /opt/hermes/hermes_cli/web_dist

ENV HERMES_DASHBOARD=1
ENV HERMES_DASHBOARD_HOST=0.0.0.0
ENV HERMES_DASHBOARD_PORT=9119

EXPOSE 9119

CMD ["gateway", "run"]
