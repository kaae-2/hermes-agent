# CapRover production environment for Hermes Agent.
# Copy values into the CapRover app's Environment Variables UI.
# Do not commit real secrets.

# CapRover routes one HTTP app port. Use the authenticated dashboard during
# setup. After setup, set HERMES_DASHBOARD=0 and redeploy if you want normal
# administration to happen only through SSH/docker exec.
HERMES_DASHBOARD=1
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_PUBLIC_URL=https://hermes.example.com

# Preferred for public VPS deployments: OAuth or OIDC.
# Register with:
#   docker exec -it <container> hermes dashboard register --redirect-uri https://hermes.example.com/auth/callback
# Then set the issued client id here.
HERMES_DASHBOARD_OAUTH_CLIENT_ID=

# Post-setup closed-dashboard mode:
# HERMES_DASHBOARD=0

# Alternative only behind VPN/Tailscale/trusted LAN. Prefer PASSWORD_HASH over
# plaintext PASSWORD. Generate a hash with:
#   docker exec -it <container> python -c "from plugins.dashboard_auth.basic import hash_password; print(hash_password('REPLACE_ME'))"
# HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
# HERMES_DASHBOARD_BASIC_AUTH_PASSWORD_HASH=
# HERMES_DASHBOARD_BASIC_AUTH_SECRET=

# Keep the OpenAI-compatible API server disabled unless you explicitly need it.
# It can dispatch terminal-capable agent work, so exposing it is an authenticated
# remote-code-execution surface by design.
API_SERVER_ENABLED=false
# API_SERVER_HOST=0.0.0.0
# API_SERVER_PORT=8642
# API_SERVER_KEY=
# API_SERVER_CORS_ORIGINS=https://exact-client.example.com

# File-write containment for Docker deployments. The official image also sets
# this, but keeping it explicit in CapRover makes the production boundary clear.
HERMES_WRITE_SAFE_ROOT=/opt/data

# Gateway adapters must be allowlisted per platform. Do not open globally.
GATEWAY_ALLOW_ALL_USERS=false

# Provider and platform secrets. Store real values only in CapRover secrets/env.
# OPENROUTER_API_KEY=
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# DISCORD_ALLOWED_ROLES=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
